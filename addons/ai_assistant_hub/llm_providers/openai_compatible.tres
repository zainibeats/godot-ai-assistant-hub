[ext_resource type="Script" path="res://addons/ai_assistant_hub/llm_providers/llm_provider_resource.gd" id="1_openai_compatible"]

[resource]
script = ExtResource("1_openai_compatible")
api_id = "openai_compatible_api"
name = "OpenAI Compatible"
description = "Generic OpenAI-compatible Chat Completions endpoint. Configure a base URL such as http://localhost:1234/v1."
reasoning_levels = Array[String](["Default", "Disabled | For compatible reasoning models, sends reasoning_effort none", "Minimal | For compatible reasoning models, spends the smallest supported reasoning effort", "Low | For compatible reasoning models, spends less reasoning effort", "Medium | For compatible reasoning models, spends medium reasoning effort", "High | For compatible reasoning models, spends more reasoning effort", "Extra High | For compatible reasoning models that support xhigh reasoning effort"])
supports_streaming = true
supports_tools = true
supports_structured_output = true
supports_reasoning_effort = true
supports_json_schema = true
requires_key = false
supports_optional_key = true
get_key_url = ""
fix_url = ""
models_url_postfix = "/models"
chat_url_postfix = "/chat/completions"
system_role_name = "system"
user_role_name = "user"
assistant_role_name = "assistant"
